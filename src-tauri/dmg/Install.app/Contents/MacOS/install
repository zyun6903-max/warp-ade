#!/bin/bash
set -e

# MacOS/install → Install.app 根目录 → DMG 挂载点
INSTALLER_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
VOL="$(dirname "${INSTALLER_ROOT}")"
APP="${VOL}/warp-ade.app"
TARGET="/Applications/warp-ade.app"

if [[ ! -d "${APP}" ]]; then
  APP="$(find "${VOL}" -maxdepth 1 -name '*.app' ! -name '安装 warp-ade.app' -type d 2>/dev/null | head -1)"
fi

if [[ ! -d "${APP}" ]]; then
  osascript -e 'display alert "安装失败" message "未找到 warp-ade.app，请重新下载安装包。"'
  exit 1
fi

xattr -cr "${VOL}" 2>/dev/null || true
[[ -d "${TARGET}" ]] && rm -rf "${TARGET}"
cp -R "${APP}" "${TARGET}"
xattr -cr "${TARGET}"
open "${TARGET}"
