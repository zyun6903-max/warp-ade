#!/bin/bash
set -e
VOL="$(cd "$(dirname "$0")/../../.." && pwd)"
APP="${VOL}/warp-ade.app"
TARGET="/Applications/warp-ade.app"

if [[ ! -d "${APP}" ]]; then
  osascript -e 'display alert "安装失败" message "未找到 warp-ade.app，请重新下载安装包。"'
  exit 1
fi

xattr -cr "${VOL}" 2>/dev/null || true
[[ -d "${TARGET}" ]] && rm -rf "${TARGET}"
cp -R "${APP}" "${TARGET}"
xattr -cr "${TARGET}"
open "${TARGET}"
